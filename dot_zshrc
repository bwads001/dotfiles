# Browse and open WebOps docs
docs() {
  local file
  file=$(fd -e md . ~/WebOps/docs | fzf --preview 'glow -s dark {}' --preview-window 'down,70%,border-top')
  [ -n "$file" ] && nvim "$file"
}

