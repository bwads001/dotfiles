# Tmux - smart session management
# t / tmux: attach to "main" session, or create it if it doesn't exist
# ta: fzf session picker (or create new named session)
# tl: list sessions
t() {
  if [ -n "$TMUX" ]; then
    echo "Already inside tmux."
    return 0
  fi
  if tmux has-session -t main 2>/dev/null; then
    tmux attach -t main
  else
    tmux new-session -s main
  fi
}

ta() {
  if [ -n "$TMUX" ]; then
    # Inside tmux: switch session via fzf
    local session
    session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | fzf --prompt="Switch session> " --header="Enter name to create new")
    if [ -n "$session" ]; then
      tmux switch-client -t "$session" 2>/dev/null || tmux new-session -d -s "$session" && tmux switch-client -t "$session"
    fi
    return 0
  fi
  # Outside tmux: pick a session to attach or create one
  local sessions
  sessions=$(tmux list-sessions -F '#{session_name}: #{session_windows} windows (#{session_attached} attached)' 2>/dev/null)
  if [ -z "$sessions" ]; then
    echo "No sessions. Creating 'main'..."
    tmux new-session -s main
    return
  fi
  local choice
  choice=$(echo "$sessions" | fzf --prompt="Attach session> " --header="Type a name + Enter to create new")
  if [ -n "$choice" ]; then
    local name="${choice%%:*}"
    tmux attach -t "$name" 2>/dev/null || tmux new-session -s "$name"
  fi
}

alias tl='tmux list-sessions'
alias tn='tmux new-session -s'

# Kill session and scrub it from resurrect save file
tk() {
  if [ -z "$1" ]; then
    echo "Usage: tk <session-name>"
    return 1
  fi
  tmux kill-session -t "$1" 2>/dev/null
  # Remove killed session from resurrect save so it doesn't come back
  local save_dir="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect"
  local save_file="$save_dir/last"
  if [ -L "$save_file" ]; then
    local target="$(readlink "$save_file")"
    [ ! "${target:0:1}" = "/" ] && target="$save_dir/$target"
    if [ -f "$target" ]; then
      sed -i '' "/^pane	${1}	/d;/^window	${1}	/d;/^state	${1}/d" "$target"
    fi
  fi
}

# File manager (yazi with CWD sync)
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

